{
  "title": "grocr",
  "uid": "grocr-main",
  "timezone": "browser",
  "refresh": "1h",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Total Spent (CZK)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "grocr",
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [{
        "rawSql": "SELECT SUM(total_czk) AS value FROM receipts",
        "format": "table"
      }]
    },
    {
      "id": 2,
      "title": "Total Receipts",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "grocr",
      "options": { "colorMode": "value", "graphMode": "none" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value FROM receipts",
        "format": "table"
      }]
    },
    {
      "id": 3,
      "title": "Avg Basket Size (CZK)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "grocr",
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } },
      "targets": [{
        "rawSql": "SELECT ROUND(AVG(total_czk)::numeric, 1) AS value FROM receipts",
        "format": "table"
      }]
    },
    {
      "id": 4,
      "title": "Spend by Store",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": "grocr",
      "options": { "legendDisplayMode": "list", "pieType": "pie" },
      "targets": [{
        "rawSql": "SELECT store, SUM(total_czk) AS total FROM receipts GROUP BY store ORDER BY total DESC",
        "format": "table"
      }],
      "transformations": [{ "id": "labelsToFields", "options": {} }]
    },
    {
      "id": 5,
      "title": "Weekly Spend (CZK)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "grocr",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "targets": [{
        "rawSql": "SELECT DATE_TRUNC('week', date::timestamptz) AS time, SUM(total_czk) AS \"CZK\" FROM receipts WHERE date IS NOT NULL GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }]
    },
    {
      "id": 6,
      "title": "Top 20 Most Bought Products",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 10 },
      "datasource": "grocr",
      "options": { "orientation": "horizontal", "legend": { "displayMode": "hidden" } },
      "targets": [{
        "rawSql": "SELECT name, COUNT(*) AS purchases FROM receipt_items WHERE name IS NOT NULL AND name != '' GROUP BY name ORDER BY purchases DESC LIMIT 20",
        "format": "table"
      }]
    },
    {
      "id": 7,
      "title": "Top 20 by Total Spend (CZK)",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 10 },
      "datasource": "grocr",
      "options": { "orientation": "horizontal", "legend": { "displayMode": "hidden" } },
      "targets": [{
        "rawSql": "SELECT name, ROUND(SUM(total_price_czk)::numeric, 0) AS total FROM receipt_items WHERE name IS NOT NULL AND name != '' GROUP BY name ORDER BY total DESC LIMIT 20",
        "format": "table"
      }]
    },
    {
      "id": 8,
      "title": "Shopping Hour of Day",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": "grocr",
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{
        "rawSql": "SELECT EXTRACT(HOUR FROM date::timestamptz)::int AS hour, COUNT(*) AS trips FROM receipts WHERE date IS NOT NULL GROUP BY hour ORDER BY hour",
        "format": "table"
      }]
    },
    {
      "id": 9,
      "title": "Shopping Day of Week",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": "grocr",
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{
        "rawSql": "SELECT TO_CHAR(date::timestamptz, 'Day') AS day, EXTRACT(DOW FROM date::timestamptz)::int AS dow, COUNT(*) AS trips FROM receipts WHERE date IS NOT NULL GROUP BY day, dow ORDER BY dow",
        "format": "table"
      }]
    },
    {
      "id": 10,
      "title": "Monthly Spend Trend",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 8 },
      "datasource": "grocr",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{
        "rawSql": "SELECT TO_CHAR(DATE_TRUNC('month', date::timestamptz), 'YYYY-MM') AS month, ROUND(SUM(total_czk)::numeric, 0) AS \"CZK\" FROM receipts WHERE date IS NOT NULL GROUP BY 1 ORDER BY 1",
        "format": "table"
      }]
    }
  ]
}
